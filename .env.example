# Stripe (test mode keys to start — https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET

# Supabase project (https://supabase.com/dashboard -> Project Settings -> API)
SUPABASE_URL=REPLACE_WITH_YOUR_SUPABASE_PROJECT_URL
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_YOUR_SUPABASE_SECRET_KEY

# Your deployed site URL (used to build Stripe's success/cancel redirect links)
# Locally this can stay as http://localhost:8888
SITE_URL=https://your-site-name.netlify.app
